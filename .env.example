# ============================================================
# APPLICATION SETTINGS
# ============================================================
NODE_ENV=development
PORT=3000
APP_NAME=Vale Alimentacao API
APP_URL=http://localhost:3000

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=database
DB_USER=postgres
DB_PASSWORD=password
DB_DIALECT=postgres

# ============================================================
# JWT - JSON Web Token
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# CLOUDINARY - Image Storage
# ============================================================
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=dfgfdgsfdgfdg
CLOUDINARY_API_KEY=123456789123456
CLOUDINARY_API_SECRET=mds_jk_jkfrdgkjerkgjkerj
CLOUDINARY_ASSET_FOLDER=pasta_projeto
# Signed URL expiration in seconds (default: 3600 = 1 hour)
CLOUDINARY_SIGNED_URL_EXPIRES=3600

# ============================================================
# EMAIL - SMTP for Alert Notifications (Pino Logger)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ============================================================
# SECURITY
# ============================================================
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3001

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
# Threshold in ms for slow request alerts
SLOW_REQUEST_THRESHOLD=2000
# Max errors per minute before email alert
ERROR_RATE_THRESHOLD=10

# ============================================================
# ADMIN CREATE
# ============================================================
ADMIN_DEFAULT_NAME=administrador
ADMIN_DEFAULT_EMAIL=admin@api.com.br
ADMIN_DEFAULT_PASSWORD=Admin@1234